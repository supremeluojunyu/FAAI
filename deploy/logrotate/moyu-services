/var/log/nginx/*.log {
    daily
    rotate 14
    missingok
    notifempty
    compress
    delaycompress
    create 0640 www-data adm
    sharedscripts
    postrotate
        [ -s /run/nginx.pid ] && kill -USR1 "$(cat /run/nginx.pid)"
    endscript
}

/home/golden/FAAI/.backend.log /home/golden/FAAI/.admin.log {
    su golden golden
    daily
    rotate 7
    missingok
    notifempty
    compress
    delaycompress
    copytruncate
}
