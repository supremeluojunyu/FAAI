NODE_ENV=production
PORT=3000
JWT_SECRET=your-super-secret-key-change-me
JWT_EXPIRES_IN=7d
SMS_PROVIDER=mock
SMS_CODE_TTL_SEC=300
WECHAT_APPID=wx1234567890
WECHAT_APPSECRET=your-wechat-app-secret

DATABASE_URL=postgresql://user:password@localhost:5432/mouldb
REDIS_URL=redis://localhost:6379

S3_ENDPOINT=https://s3.amazonaws.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET_MODELS=model-files
S3_BUCKET_COVERS=model-covers
S3_BUCKET_AVATARS=user-avatars
S3_BUCKET_POSTS=post-media

WECHAT_APPID=wx1234567890
WECHAT_MCHID=1230000109
WECHAT_KEY=your-wechat-pay-key
WECHAT_CERT_PATH=/path/to/apiclient_cert.pem
WECHAT_NOTIFY_URL=https://api.yourdomain.com/api/v1/payment/wechat-callback

ALIPAY_APPID=2021000123456789
ALIPAY_PRIVATE_KEY=/path/to/alipay_private_key.pem
ALIPAY_PUBLIC_KEY=/path/to/alipay_public_key.pem
ALIPAY_NOTIFY_URL=https://api.yourdomain.com/api/v1/payment/alipay-callback

JPUSH_APPKEY=your-jpush-appkey
JPUSH_MASTER_SECRET=your-jpush-master-secret

CONVERT_API_URL=http://localhost:8080/convert
CONVERT_API_KEY=your-convert-api-key

CONFIG_CDN_PUBLISH_URL=https://cdn.yourdomain.com/publish-config
